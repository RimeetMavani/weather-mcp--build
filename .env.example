# Free API keys (optional — 3 tools work without any keys)
#
# OpenWeatherMap — free tier: 1,000 calls/day
# Sign up: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# WeatherAPI.com — free tier: 1,000,000 calls/month
# Sign up: https://www.weatherapi.com/signup.aspx
WEATHERAPI_KEY=your_weatherapi_key_here

# Groq — free tier LLM for inbox (agent.py)
# Sign up: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Agent settings (optional)
MCP_SSE_URL=http://127.0.0.1:8000/sse
AGENT_HOST=127.0.0.1
AGENT_PORT=8001
